generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  SHOP_OWNER
  SERVICE_ADVISOR
  TECHNICIAN
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionPlan {
  PROFESSIONAL
  BUSINESS
}

enum DeviceType {
  MOBILE
  LAPTOP
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  RECEIVED
  DIAGNOSIS
  IN_PROGRESS
  READY_FOR_PICKUP
  COMPLETED
  PAYMENT_COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
}

enum LineItemType {
  PART
  SERVICE_FEE
  DISCOUNT
  EXTRA_CHARGE
}

model Tenant {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  domain           String           @unique
  status           TenantStatus     @default(ACTIVE)
  subscriptionPlan SubscriptionPlan @default(PROFESSIONAL)
  contactName      String           @default("")
  email            String           @default("")
  phone            String           @default("")
  mobile           String?
  primaryColor     String           @default("#3b82f6")
  logoUrl          String?
  users            User[]
  customers        Customer[]
  tickets          Ticket[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model User {
  id              String           @id @default(cuid())
  tenantId        String?
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  email           String           @unique
  passwordHash    String
  role            UserRole
  isActive        Boolean          @default(true)
  assignedTickets Ticket[]         @relation("AssignedTechnician")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  ticketLineItems TicketLineItem[]

  @@index([tenantId])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  email     String?
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, phone])
}

model Ticket {
  id            String           @id @default(cuid())
  tenantId      String
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId    String
  customer      Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  technicianId  String?
  technician    User?            @relation("AssignedTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  ticketNumber  String
  issue         String
  description   String?
  deviceType    DeviceType       @default(MOBILE)
  deviceBrand   String?
  deviceModel   String
  deviceColor   String?
  imei          String?
  condition     String?
  accessories   String?
  priority      TicketPriority   @default(MEDIUM)
  status        TicketStatus     @default(RECEIVED)
  estimatedCost Decimal?         @db.Decimal(12, 2)
  invoiceAmount Decimal?         @db.Decimal(12, 2)
  paymentStatus PaymentStatus    @default(PENDING)
  completedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  lineItems     TicketLineItem[]

  @@unique([tenantId, ticketNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([technicianId])
}

model TicketLineItem {
  id         String       @id @default(cuid())
  ticketId   String
  ticket     Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type       LineItemType
  name       String
  quantity   Int          @default(1)
  unitPrice  Decimal      @db.Decimal(12, 2)
  totalPrice Decimal      @db.Decimal(12, 2)
  addedById  String
  addedBy    User         @relation(fields: [addedById], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([ticketId])
}
