generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  SHOP_OWNER
  SERVICE_ADVISOR
  TECHNICIAN
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionPlan {
  STARTER
  BUSINESS
  ENTERPRISE
}

enum DeviceType {
  MOBILE
  LAPTOP
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  RECEIVED
  DIAGNOSIS
  IN_PROGRESS
  READY_FOR_PICKUP
  COMPLETED
  PAYMENT_COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
}

enum LineItemType {
  PART
  SERVICE_FEE
  DISCOUNT
  EXTRA_CHARGE
}

enum WhatsAppStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum NotificationType {
  REPAIR_RECEIVED
  STATUS_UPDATE
  READY_FOR_PICKUP
  INVOICE_DELIVERY
  TRACKING_LINK
  DELIVERY_CONFIRMATION
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model Tenant {
  id                   String           @id @default(cuid())
  name                 String
  slug                 String           @unique
  domain               String           @unique
  status               TenantStatus     @default(ACTIVE)
  subscriptionPlan     SubscriptionPlan @default(STARTER)
  subscriptionStartDate DateTime        @default(now())
  subscriptionEndDate   DateTime        @default(now())
  customPriceInr       Int?
  periodTicketCount    Int              @default(0)
  // Queued plan (for downgrades or scheduled next plan)
  queuedPlan             SubscriptionPlan?
  queuedPlanStartDate    DateTime?
  queuedPlanEndDate      DateTime?
  queuedPlanCustomPriceInr Int?
  contactName          String           @default("")
  email                String           @default("")
  phone                String           @default("")
  mobile               String?
  primaryColor         String           @default("#3b82f6")
  logoUrl              String?
  users                User[]
  customers            Customer[]
  tickets              Ticket[]
  branches             Branch[]
  whatsapp             TenantWhatsapp?
  notificationUsage    NotificationUsage[]
  notificationLogs     NotificationLog[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model TenantWhatsapp {
  id                String         @id @default(cuid())
  tenantId          String         @unique
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumberId     String
  businessAccountId String
  accessToken       String
  wabaPhoneNumber   String
  status            WhatsAppStatus @default(CONNECTED)
  connectedAt       DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model NotificationUsage {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  month    String
  used     Int    @default(0)
  limit    Int    @default(1000)

  @@unique([tenantId, month])
  @@index([tenantId])
}

model NotificationLog {
  id            String             @id @default(cuid())
  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId      String?
  customerPhone String
  customerName  String?
  type          NotificationType
  status        NotificationStatus @default(PENDING)
  metaMessageId String?
  errorMessage  String?
  sentAt        DateTime           @default(now())

  @@index([tenantId])
  @@index([ticketId])
}

model User {
  id              String           @id @default(cuid())
  tenantId        String?
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  email           String           @unique
  passwordHash    String
  role            UserRole
  isActive        Boolean          @default(true)
  assignedTickets Ticket[]         @relation("AssignedTechnician")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  ticketLineItems TicketLineItem[]

  @@index([tenantId])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  email     String?
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, phone])
}

model Ticket {
  id            String           @id @default(cuid())
  tenantId      String
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId    String
  customer      Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  technicianId  String?
  technician    User?            @relation("AssignedTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  ticketNumber  String
  issue         String
  description   String?
  deviceType    DeviceType       @default(MOBILE)
  deviceBrand   String?
  deviceModel   String
  deviceColor   String?
  imei          String?
  condition     String?
  accessories   String?
  priority      TicketPriority   @default(MEDIUM)
  status        TicketStatus     @default(RECEIVED)
  estimatedCost Decimal?         @db.Decimal(12, 2)
  invoiceAmount Decimal?         @db.Decimal(12, 2)
  paymentStatus PaymentStatus    @default(PENDING)
  completedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  lineItems     TicketLineItem[]

  @@unique([tenantId, ticketNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([technicianId])
}

model TicketLineItem {
  id         String       @id @default(cuid())
  ticketId   String
  ticket     Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type       LineItemType
  name       String
  quantity   Int          @default(1)
  unitPrice  Decimal      @db.Decimal(12, 2)
  totalPrice Decimal      @db.Decimal(12, 2)
  addedById  String
  addedBy    User         @relation(fields: [addedById], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([ticketId])
}
